<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>عرين</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&family=Lalezar&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --cream:#f0e6cc;
  --dots:#d8c9a8;
  --text:#2a1500;
  --text-b:#6a3c10;
  /* cartoon node colors matching screenshot */
  --done-face:#e8c050;
  --done-side:#c09020;
  --active-face:#e8a050;
  --active-side:#b06020;
  --locked-face-dark:#7a6248;
  --locked-side-dark:#4a3020;
  --locked-face-light:#a09060;
  --locked-side-light:#70602a;
  --lock-badge:#c8c0a8;
  --lock-badge-b:#988870;
}
body{font-family:"Tajawal",sans-serif;background:var(--cream);min-height:100vh;overflow-x:hidden;}
body::before{content:"";position:fixed;inset:0;z-index:0;
  background-image:radial-gradient(circle,var(--dots) 1.5px,transparent 1.5px);
  background-size:20px 20px;opacity:0.6;pointer-events:none;}
.screen{position:relative;z-index:1;}
.hidden{display:none!important;}

/* PRESS */
.pressable{transition:transform 0.12s cubic-bezier(0.34,1.56,0.64,1);cursor:pointer;}
.pressable:active{transform:scale(0.9)!important;}

/* TOP BAR */
.top-bar{
  position:sticky;top:0;z-index:50;
  background:#e8d8b4;border-bottom:3px solid #c8b890;
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 16px;height:58px;
}
.back-btn{
  width:42px;height:42px;background:#fff8e8;
  border:3px solid #c8b060;border-radius:14px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;font-weight:900;color:var(--text);
  box-shadow:0 4px 0 #a09040;
}
.bar-title{font-size:1.2rem;font-weight:900;color:var(--text);}
.coin-bar{
  display:flex;align-items:center;gap:5px;
  background:#fff8e0;border:3px solid #d4b040;border-radius:50px;
  padding:5px 14px;font-weight:900;font-size:1rem;color:#8a5800;
  box-shadow:0 3px 0 #b09020;
}

/* ===== START SCREEN ===== */
#start-screen{
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:30px 20px;text-align:center;
}
.s-title-wrap{margin-bottom:28px;}
.s-title-main{
  font-family:"Lalezar",sans-serif;
  font-size:5.5rem;font-weight:400;
  color:#c87020;
  text-shadow:
    3px 3px 0 #8a4010,
    -1px -1px 0 #8a4010,
    1px -1px 0 #8a4010,
    -1px 1px 0 #8a4010,
    0 4px 0 #6a2808,
    0 6px 12px rgba(0,0,0,0.15);
  line-height:1;letter-spacing:-2px;
  animation:titlePop 0.8s cubic-bezier(0.34,1.56,0.64,1) both;
}
@keyframes titlePop{from{transform:scale(0.5) rotate(-5deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.s-title-sub{
  font-size:1rem;font-weight:700;color:#b08040;
  letter-spacing:3px;margin-top:4px;
}

/* Cartoon character icon */
.s-char{
  font-size:4rem;margin-bottom:10px;
  animation:charBob 2.5s ease-in-out infinite;
}
@keyframes charBob{0%,100%{transform:translateY(0) rotate(-2deg)}50%{transform:translateY(-8px) rotate(2deg)}}

/* Yellow start button - cartoon style */
.s-play-btn{
  position:relative;border:none;background:transparent;cursor:pointer;
  margin-bottom:20px;
}
.s-play-face{
  background:linear-gradient(to bottom,#ffe060,#f0b820);
  border-radius:20px;
  border:3px solid #c08000;
  padding:16px 70px;
  font-family:"Tajawal",sans-serif;
  font-size:1.6rem;font-weight:900;
  color:#5a2e00;
  box-shadow:0 6px 0 #8a5800,0 8px 20px rgba(0,0,0,0.2);
  transition:transform 0.12s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.12s;
  display:flex;align-items:center;gap:10px;
}
.s-play-btn:active .s-play-face{
  transform:translateY(5px);
  box-shadow:0 1px 0 #8a5800,0 2px 8px rgba(0,0,0,0.15);
}
.s-mini-row{display:flex;gap:14px;justify-content:center;}
.s-mini-btn{
  width:70px;height:60px;border:none;border-radius:18px;
  background:linear-gradient(to bottom,#f0e2c0,#d8c898);
  border:3px solid #c0a060;
  box-shadow:0 5px 0 #907030,0 6px 14px rgba(0,0,0,0.1);
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;cursor:pointer;
  transition:transform 0.12s cubic-bezier(0.34,1.56,0.64,1);
}
.s-mini-btn:active{transform:scale(0.88) translateY(4px);}

/* ===== MAP ===== */
#map-screen{min-height:100vh;}
.map-scroll{
  position:relative;width:100%;max-width:400px;margin:0 auto;
  padding:20px 0 80px;
}

/* CARTOON LEVEL NODE */
.level-slot{
  position:absolute;z-index:2;
  display:flex;flex-direction:column;align-items:center;
}

/* The cartoon button with thick rounded border */
.lvl-btn{
  width:76px;height:76px;
  border:none;background:transparent;cursor:pointer;padding:0;
  position:relative;
}
.lvl-face{
  width:76px;height:76px;
  border-radius:18px;
  display:flex;align-items:center;justify-content:center;flex-direction:column;
  font-family:"Tajawal",sans-serif;font-weight:900;font-size:1.6rem;
  position:relative;
  transition:transform 0.12s cubic-bezier(0.34,1.56,0.64,1);
  /* Cartoon thick outline */
  outline:none;
}

/* DONE - yellow/gold like screenshot */
.lvl-btn.done .lvl-face{
  background:linear-gradient(145deg,#ffe878,#e8c028);
  border:3px solid #c09010;
  box-shadow:0 6px 0 #a07000,0 7px 18px rgba(0,0,0,0.2);
  color:#5a3000;
}

/* ACTIVE - orange like screenshot node 2 */
.lvl-btn.active .lvl-face{
  background:linear-gradient(145deg,#f4a060,#e07030);
  border:3px solid #c05010;
  box-shadow:0 6px 0 #903010,0 7px 18px rgba(0,0,0,0.2);
  color:#fff;
  animation:nodePulse 2s ease-in-out infinite;
}
@keyframes nodePulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}

/* LOCKED variants - alternating like screenshot */
.lvl-btn.locked-d .lvl-face{
  background:linear-gradient(145deg,#9a8060,#7a6040);
  border:3px solid #5a4020;
  box-shadow:0 6px 0 #3a2010,0 7px 18px rgba(0,0,0,0.2);
  color:#c0a880;
}
.lvl-btn.locked-l .lvl-face{
  background:linear-gradient(145deg,#c0b080,#a09060);
  border:3px solid #807040;
  box-shadow:0 6px 0 #605020,0 7px 18px rgba(0,0,0,0.2);
  color:#5a4020;
}

.lvl-btn:active .lvl-face{
  transform:translateY(5px)!important;
  box-shadow:0 1px 0 #3a2010!important;
}

/* Lock badge */
.lvl-lock{
  position:absolute;top:-9px;left:-9px;
  width:26px;height:26px;
  background:#d0c8a8;border:3px solid #a09060;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:0.6rem;box-shadow:0 2px 0 #807040;
}

/* Done checkmark badge */
.lvl-done-badge{
  position:absolute;top:-8px;left:-8px;
  width:22px;height:22px;
  background:#50c840;border:3px solid #30a020;
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:0.6rem;color:#fff;font-weight:900;
  box-shadow:0 2px 0 #208010;
}

/* Stars */
.lvl-stars{display:flex;gap:2px;margin-top:1px;}
.lvl-stars span{font-size:0.65rem;color:#c8a030;}

.lvl-qcount{font-size:0.6rem;opacity:0.7;font-weight:700;}
.lvl-name{margin-top:5px;font-size:0.72rem;font-weight:700;color:var(--text-b);}

/* ===== QUESTION SCREEN ===== */
#question-screen{
  min-height:calc(100vh - 58px);
  display:flex;flex-direction:column;align-items:center;
  padding:14px 14px 40px;
}
.q-toprow{
  width:100%;max-width:500px;
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:12px;
}
.q-coins-badge{
  display:flex;align-items:center;gap:5px;
  background:#fff8e0;border:3px solid #d4b040;border-radius:50px;
  padding:5px 14px;font-weight:900;font-size:1rem;color:#7a5000;
  box-shadow:0 3px 0 #b09020;
}
.hint-shop-btn{
  display:flex;align-items:center;gap:6px;
  background:linear-gradient(to bottom,#f0e2c0,#d8c898);
  border:3px solid #c0a060;border-radius:14px;
  padding:8px 14px;cursor:pointer;
  font-family:"Tajawal",sans-serif;font-size:0.9rem;font-weight:700;
  color:var(--text);box-shadow:0 4px 0 #907030;
  transition:transform 0.12s cubic-bezier(0.34,1.56,0.64,1);
}
.hint-shop-btn:active{transform:scale(0.9) translateY(3px);box-shadow:0 1px 0 #907030;}
.q-prog-row{
  display:flex;gap:5px;justify-content:center;
  margin-bottom:12px;flex-wrap:wrap;max-width:500px;
}
.q-dot{width:10px;height:10px;border-radius:50%;background:#c8b888;}
.q-dot.done{background:#68b028;}
.q-dot.current{background:#e09828;}
.q-card{
  width:100%;max-width:500px;background:#fff;
  border:3px solid #e0d0b0;border-radius:20px;
  padding:24px 20px;
  box-shadow:0 4px 0 #c8b888,0 5px 18px rgba(0,0,0,0.08);
  margin-bottom:14px;
}
.q-cat-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:var(--cream);border:2px solid #d8c898;
  border-radius:20px;padding:3px 12px;
  font-size:0.8rem;font-weight:700;color:var(--text-b);margin-bottom:10px;
}
.q-text{font-size:1.3rem;font-weight:700;color:var(--text);text-align:center;line-height:1.8;}

.hint-revealed{
  background:#fffbe8;border:3px solid #e0c060;border-radius:16px;
  padding:10px 16px;font-size:0.92rem;font-weight:700;
  color:#6a4000;text-align:center;margin-bottom:12px;
  display:none;width:100%;max-width:500px;
}
.hint-revealed.show{display:block;animation:fadeSlide 0.4s ease;}
@keyframes fadeSlide{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}

.ans-row{
  display:flex;gap:8px;justify-content:center;
  margin-bottom:14px;direction:rtl;flex-wrap:wrap;
}
.ans-box{
  min-width:42px;height:44px;padding:0 6px;
  background:#fff;border:3px solid #c8b880;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;font-weight:700;color:var(--text);
}
.ans-box.correct{background:#d8f0b0;border-color:#50a010;color:#1a5808;animation:popIn 0.3s cubic-bezier(0.34,1.56,0.64,1);}
.ans-box.wrong{background:#f8d0b8;border-color:#c05030;color:#801818;animation:shake 0.4s;}
@keyframes popIn{from{transform:scale(0.7)}to{transform:scale(1)}}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}

.opts-wrap{
  width:100%;max-width:500px;
  display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;
}
.opt-btn{border:none;background:transparent;cursor:pointer;border-radius:18px;padding:0;}
.opt-face{
  background:linear-gradient(to bottom,#ede2c8,#d8c898);
  border-radius:18px;padding:14px 10px;text-align:center;
  font-family:"Tajawal",sans-serif;font-size:1.05rem;font-weight:700;
  color:var(--text);border:3px solid #c0a860;
  box-shadow:0 5px 0 #a08840;
  transition:transform 0.1s cubic-bezier(0.34,1.56,0.64,1);
}
.opt-btn:active .opt-face{transform:translateY(4px);box-shadow:0 1px 0 #a08840;}
.opt-btn.correct .opt-face{
  background:linear-gradient(to bottom,#c0e880,#78c030);
  border-color:#50a010;box-shadow:0 5px 0 #30780a;color:#1a4808;
  animation:popIn 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.opt-btn.wrong .opt-face{
  background:linear-gradient(to bottom,#f0a080,#d05030);
  border-color:#a02810;box-shadow:0 5px 0 #701808;color:#fff;
  animation:shake 0.4s;
}

/* ===== BOTTOM SHEETS ===== */
.sheet-bg{
  position:fixed;inset:0;background:rgba(0,0,0,0.0);z-index:90;
  opacity:0;transition:opacity 0.3s;pointer-events:none;
}
.sheet-bg.on{opacity:1;pointer-events:all;}

/* CORRECT SHEET - compact, centered bottom */
.correct-sheet{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);
  width:100%;max-width:480px;
  z-index:95;
  background:var(--cream);
  border-radius:28px 28px 0 0;
  padding:20px 20px 28px;
  box-shadow:0 -6px 30px rgba(0,0,0,0.15);
  border-top:3px solid #d8c898;
  pointer-events:none;
  transition:transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
}
.correct-sheet.show{transform:translateX(-50%) translateY(0);pointer-events:all;}

.cs-title{
  font-size:1.8rem;font-weight:900;color:var(--text);
  text-align:center;margin-bottom:14px;
  animation:csTitlePop 0.5s cubic-bezier(0.34,1.56,0.64,1) 0.1s both;
}
@keyframes csTitlePop{from{transform:scale(0.6);opacity:0}to{transform:scale(1);opacity:1}}

.cs-row{display:flex;gap:10px;margin-bottom:14px;}
.cs-box{
  flex:1;background:#fff;
  border:3px solid #e0d0b0;border-radius:16px;
  padding:12px 14px;
  box-shadow:0 3px 0 #c8b888;
}
.cs-box-label{font-size:0.78rem;color:#b8a080;font-weight:700;margin-bottom:4px;}
.cs-box-value{font-size:1.4rem;font-weight:900;color:var(--text);text-align:center;}
.cs-coins-pill{
  display:inline-flex;align-items:center;justify-content:center;gap:5px;
  background:#fff8e0;border:3px solid #d4b040;border-radius:50px;
  padding:5px 16px;font-size:1.1rem;font-weight:900;color:#7a5000;
  animation:pillPop 0.4s cubic-bezier(0.34,1.56,0.64,1) 0.45s both;
  width:100%;
}
@keyframes pillPop{from{transform:scale(0)}to{transform:scale(1)}}

.cs-next-btn{
  width:100%;padding:14px;margin-top:12px;
  background:linear-gradient(to bottom,#ffe060,#f0b820);
  color:#5a2e00;font-family:"Tajawal",sans-serif;
  font-size:1.25rem;font-weight:900;
  border-radius:18px;border:3px solid #c08000;cursor:pointer;
  box-shadow:0 5px 0 #8a5800;
  transition:transform 0.12s,box-shadow 0.12s;
}
.cs-next-btn:active{transform:translateY(4px);box-shadow:0 1px 0 #8a5800;}

/* WRONG SHEET */
.wrong-sheet{
  position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);
  width:100%;max-width:480px;
  z-index:95;
  background:var(--cream);
  border-radius:28px 28px 0 0;
  padding:20px 20px 28px;
  box-shadow:0 -6px 30px rgba(0,0,0,0.15);
  border-top:3px solid #e0c0b0;
  pointer-events:none;
  transition:transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
}
.wrong-sheet.show{transform:translateX(-50%) translateY(0);pointer-events:all;}
.ws-title{
  font-size:1.8rem;font-weight:900;color:#c04020;
  text-align:center;margin-bottom:14px;
  animation:csTitlePop 0.5s cubic-bezier(0.34,1.56,0.64,1) 0.1s both;
}
.ws-box{
  background:#fff;border:3px solid #f0c0a0;border-radius:16px;
  padding:12px 14px;margin-bottom:14px;
  box-shadow:0 3px 0 #e0a888;
}
.ws-box-label{font-size:0.78rem;color:#c08060;font-weight:700;margin-bottom:4px;}
.ws-box-value{font-size:1.4rem;font-weight:900;color:var(--text);text-align:center;}
.ws-next-btn{
  width:100%;padding:14px;
  background:linear-gradient(to bottom,#f08060,#d04020);
  color:#fff;font-family:"Tajawal",sans-serif;
  font-size:1.25rem;font-weight:900;
  border-radius:18px;border:3px solid #a02010;cursor:pointer;
  box-shadow:0 5px 0 #801808;
  transition:transform 0.12s,box-shadow 0.12s;
}
.ws-next-btn:active{transform:translateY(4px);box-shadow:0 1px 0 #801808;}

/* ===== HINT OV ===== */
.hint-ov-card{
  background:#fffbf0;border:3px solid #d4b040;border-radius:24px;
  padding:28px 30px;text-align:center;max-width:300px;width:90%;
  box-shadow:0 20px 60px rgba(0,0,0,0.25);
  transform:scale(0.8);transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
}
.hint-ov-inner{
  position:fixed;inset:0;z-index:95;
  display:none;flex-direction:column;
  align-items:center;justify-content:center;
}
.hint-ov-inner.on{display:flex;}
.hint-ov-inner.on .hint-ov-card{transform:scale(1);}
.hint-ov-title{font-size:1.4rem;font-weight:900;color:var(--text);margin-bottom:8px;}
.hint-ov-text{color:var(--text-b);font-size:0.92rem;margin-bottom:14px;line-height:1.6;}
.hint-ov-cost{
  display:inline-flex;align-items:center;gap:5px;
  background:#fff8e0;border:3px solid #d4b040;border-radius:50px;
  padding:5px 16px;font-weight:900;font-size:1.05rem;color:#7a5000;
  margin-bottom:16px;
}
.hint-buy-btn{
  background:linear-gradient(to bottom,#f0d060,#c89020);
  color:#4a2800;font-family:"Tajawal",sans-serif;
  font-size:1.05rem;font-weight:900;padding:10px 28px;
  border-radius:14px;border:3px solid #a07000;cursor:pointer;
  box-shadow:0 4px 0 #8a5800;margin-left:8px;
  transition:transform 0.12s;
}
.hint-buy-btn:active{transform:scale(0.9) translateY(3px);}
.hint-cancel-btn{
  background:#e8d8b8;color:var(--text-b);
  font-family:"Tajawal",sans-serif;font-size:1.05rem;font-weight:700;
  padding:10px 22px;border-radius:14px;border:3px solid #c0b080;
  cursor:pointer;box-shadow:0 4px 0 #a09060;
  transition:transform 0.12s;
}
.hint-cancel-btn:active{transform:scale(0.9) translateY(3px);}

/* ===== LEVEL COMPLETE ===== */
#level-complete-ov{
  position:fixed;inset:0;z-index:200;
  display:none;flex-direction:column;
  align-items:center;justify-content:center;
  background:rgba(0,0,0,0.5);
}
#level-complete-ov.show{display:flex;}
.lc-card{
  background:var(--cream);border-radius:30px;
  padding:36px 44px;text-align:center;
  box-shadow:0 30px 80px rgba(0,0,0,0.3);
  border:3px solid #d8c890;
  animation:lcPop 0.6s cubic-bezier(0.34,1.56,0.64,1);
  max-width:320px;width:90%;
}
@keyframes lcPop{from{transform:scale(0) rotate(-12deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.lc-stars-row{display:flex;justify-content:center;gap:8px;margin-bottom:10px;}
.lc-star{font-size:3rem;opacity:0;animation:starPop 0.45s cubic-bezier(0.34,1.56,0.64,1) forwards;}
.lc-star:nth-child(1){animation-delay:0.25s;}
.lc-star:nth-child(2){animation-delay:0.45s;}
.lc-star:nth-child(3){animation-delay:0.65s;}
@keyframes starPop{from{transform:scale(0) rotate(-20deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.lc-title{font-size:1.9rem;font-weight:900;color:var(--text);margin-bottom:5px;}
.lc-sub{color:#8a7050;font-size:0.95rem;margin-bottom:16px;}
.lc-coins{
  display:inline-flex;align-items:center;gap:6px;
  background:#fff8e0;border:3px solid #d4b040;border-radius:50px;
  padding:6px 18px;font-weight:900;font-size:1.1rem;color:#7a5000;
  margin-bottom:20px;
  animation:coinsPop 0.5s cubic-bezier(0.34,1.56,0.64,1) 0.9s both;
  box-shadow:0 3px 0 #b09020;
}
@keyframes coinsPop{from{transform:scale(0)}to{transform:scale(1)}}
.lc-btn{
  background:linear-gradient(to bottom,#ffe060,#f0b820);
  color:#5a2e00;font-family:"Tajawal",sans-serif;
  font-size:1.2rem;font-weight:900;padding:13px 44px;
  border-radius:18px;border:3px solid #c08000;cursor:pointer;
  box-shadow:0 5px 0 #8a5800;
  transition:transform 0.12s,box-shadow 0.12s;
}
.lc-btn:active{transform:translateY(4px);box-shadow:0 1px 0 #8a5800;}

/* ===== SETTINGS ===== */
#settings-ov{
  position:fixed;inset:0;z-index:200;
  display:none;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(0,0,0,0.45);
}
#settings-ov.on{display:flex;}
.settings-card{
  background:var(--cream);border-radius:28px;
  padding:28px 26px;max-width:310px;width:90%;
  box-shadow:0 20px 60px rgba(0,0,0,0.25);
  border:3px solid #d4b878;
  animation:fadeInScale 0.35s cubic-bezier(0.34,1.56,0.64,1);
}
@keyframes fadeInScale{from{transform:scale(0.8);opacity:0}to{transform:scale(1);opacity:1}}
.settings-title{font-size:1.5rem;font-weight:900;color:var(--text);margin-bottom:18px;text-align:center;}
.setting-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 0;border-bottom:2px solid #e8d8b8;
}
.setting-row:last-of-type{border-bottom:none;}
.setting-label{font-size:0.95rem;font-weight:700;color:var(--text-b);}
.toggle-wrap{
  width:52px;height:28px;border-radius:14px;
  background:#ccc;position:relative;cursor:pointer;
  transition:background 0.25s;border:2px solid #aaa;
}
.toggle-wrap.on{background:#e09828;border-color:#b07018;}
.toggle-knob{
  position:absolute;top:2px;right:2px;
  width:20px;height:20px;border-radius:50%;
  background:#fff;box-shadow:0 1px 4px rgba(0,0,0,0.25);
  transition:right 0.25s;
}
.toggle-wrap.on .toggle-knob{right:auto;left:2px;}
.lang-btns{display:flex;gap:6px;}
.lang-btn{
  padding:5px 12px;border-radius:10px;
  font-family:"Tajawal",sans-serif;font-size:0.88rem;font-weight:700;
  border:2px solid #c8b070;cursor:pointer;
  background:#f0e8d0;color:var(--text);transition:all 0.2s;
}
.lang-btn.active{background:#e09828;color:#fff;border-color:#b07018;}
.settings-close{
  width:100%;padding:12px;margin-top:16px;
  background:linear-gradient(to bottom,#ffe060,#f0b820);
  color:#5a2e00;font-family:"Tajawal",sans-serif;
  font-size:1.05rem;font-weight:900;
  border:3px solid #c08000;border-radius:16px;cursor:pointer;
  box-shadow:0 4px 0 #8a5800;
  transition:transform 0.12s,box-shadow 0.12s;
}
.settings-close:active{transform:translateY(3px);box-shadow:0 1px 0 #8a5800;}

/* Float effects */
.float-coin{
  position:fixed;font-size:1.3rem;font-weight:900;
  color:#c08000;pointer-events:none;z-index:300;
  animation:floatUp 1.3s ease forwards;
}
@keyframes floatUp{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-90px) scale(1.5)}}
.cf{position:fixed;pointer-events:none;z-index:201;}
@keyframes cfFall{to{transform:translateY(110vh) rotate(600deg);opacity:0;}}

/* Ripple */
.ripple{
  position:absolute;border-radius:50%;
  background:rgba(255,255,255,0.35);
  transform:scale(0);animation:rippleAnim 0.5s linear;
  pointer-events:none;
}
@keyframes rippleAnim{to{transform:scale(4);opacity:0;}}
</style>
</head>
