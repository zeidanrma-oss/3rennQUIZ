// AUDIO
const AudioCtx=window.AudioContext||window.webkitAudioContext;
let actx=null;
function getACtx(){if(!actx)actx=new AudioCtx();return actx;}
function playTone(freq,dur,type,vol){
  if(!settings.sfx)return;
  try{
    const ctx=getACtx(),osc=ctx.createOscillator(),gain=ctx.createGain();
    osc.connect(gain);gain.connect(ctx.destination);
    osc.type=type||'sine';osc.frequency.value=freq;
    gain.gain.setValueAtTime(vol||0.25,ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+dur);
    osc.start(ctx.currentTime);osc.stop(ctx.currentTime+dur);
  }catch(e){}
}
function playCorrect(){playTone(523,0.08,'sine',0.3);setTimeout(()=>playTone(659,0.1,'sine',0.25),80);setTimeout(()=>playTone(784,0.18,'sine',0.2),170);}
function playWrong(){playTone(200,0.15,'sawtooth',0.2);setTimeout(()=>playTone(160,0.2,'sawtooth',0.15),160);}
function playClick(){playTone(440,0.06,'sine',0.15);}
function playCoin(){playTone(880,0.08,'sine',0.2);setTimeout(()=>playTone(1100,0.12,'sine',0.15),90);}
function playLevelUp(){[523,659,784,1046].forEach((f,i)=>setTimeout(()=>playTone(f,0.18,'sine',0.2),i*120));}

// SETTINGS
const settings={sfx:true,fx:true,lang:'ar'};
function openSettings(){playClick();document.getElementById('settings-ov').classList.add('on');}
function closeSettings(){playClick();document.getElementById('settings-ov').classList.remove('on');}
function toggleSFX(){settings.sfx=!settings.sfx;document.getElementById('sfx-toggle').classList.toggle('on',settings.sfx);if(settings.sfx)playClick();}
function toggleFX(){settings.fx=!settings.fx;document.getElementById('fx-toggle').classList.toggle('on',settings.fx);}
function setLang(l){settings.lang=l;document.getElementById('lang-ar').classList.toggle('active',l==='ar');document.getElementById('lang-en').classList.toggle('active',l==='en');playClick();}

// RIPPLE
function addRipple(el,e){
  if(!settings.fx)return;
  const rect=el.getBoundingClientRect();
  const x=(e.clientX||rect.left+rect.width/2)-rect.left;
  const y=(e.clientY||rect.top+rect.height/2)-rect.top;
  const size=Math.max(rect.width,rect.height)*1.5;
  const r=document.createElement('span');r.className='ripple';
  r.style.cssText=`width:${size}px;height:${size}px;left:${x-size/2}px;top:${y-size/2}px`;
  el.style.position='relative';el.style.overflow='hidden';el.appendChild(r);
  setTimeout(()=>r.remove(),500);
}
document.addEventListener('click',e=>{
  const btn=e.target.closest('.pressable,.opt-btn,.back-btn,.lvl-btn');
  if(btn)addRipple(btn,e);
});

