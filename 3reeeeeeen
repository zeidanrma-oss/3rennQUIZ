let coins=0,done=[],curLevel=null,curQ=0,curScore=0,hintUsed=false,picking=false;

function updateCoins(){
  ['map-coins','q-coins-top','q-coins-badge'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=coins;});
}

// MAP
const ZX=[50,72,32,68,26,70,36,74,28,58,74,30,66,24,56,72,34,68,28,52,74,32,64,24,56,70,36,72,26,54,70,32,68,26,58,74,30,66,22,54];
function buildMap(){
  updateCoins();
  const wrap=document.getElementById('map-scroll');
  wrap.innerHTML='';
  const ROW_H=110,totalH=LEVELS.length*ROW_H+80;
  wrap.style.height=totalH+'px';
  const svg=document.createElementNS('http://www.w3.org/2000/svg','svg');
  svg.setAttribute('width','100%');svg.setAttribute('height',totalH);
  svg.style.cssText='position:absolute;top:0;left:0;pointer-events:none;z-index:1';
  wrap.appendChild(svg);
  const pos=[];
  LEVELS.forEach((lvl,i)=>{
    const isDone=done.includes(lvl.id);
    const isActive=!isDone&&(i===0||done.includes(LEVELS[i-1].id));
    const isLocked=!isDone&&!isActive;
    const xPct=ZX[i%ZX.length]??50;
    const yTop=20+i*ROW_H;
    pos.push({cx:(xPct/100)*400,cy:yTop+38});
    const slot=document.createElement('div');
    slot.className='level-slot';
    slot.style.cssText='left:'+xPct+'%;top:'+yTop+'px;transform:translateX(-50%)';
    const btn=document.createElement('button');
    // Alternate locked colors like screenshot
    const lockClass=isLocked?(i%2===0?'locked-d':'locked-l'):'';
    btn.className='lvl-btn pressable '+(isDone?'done':isActive?'active':lockClass);
    if(!isLocked)btn.onclick=()=>{playClick();playLevel(lvl.id);};
    const face=document.createElement('div');face.className='lvl-face';
    // Number
    const numEl=document.createElement('div');
    numEl.style.cssText='font-size:1.5rem;font-weight:900;line-height:1';
    numEl.textContent=lvl.id;
    face.appendChild(numEl);
    // Question count
    if(!isDone){
      const qc=document.createElement('div');
      qc.className='lvl-qcount';qc.textContent=lvl.qs.length+'س';
      face.appendChild(qc);
    }
    if(isLocked){
      const lk=document.createElement('div');lk.className='lvl-lock';lk.textContent='🔒';face.appendChild(lk);
    }
    if(isDone){
      const db=document.createElement('div');db.className='lvl-done-badge';db.textContent='✓';face.appendChild(db);
      const sr=document.createElement('div');sr.className='lvl-stars';
      for(let s=0;s<3;s++){const sp=document.createElement('span');sp.textContent='★';sr.appendChild(sp);}
      face.appendChild(sr);
    }
    btn.appendChild(face);slot.appendChild(btn);
    const nm=document.createElement('div');nm.className='lvl-name';nm.textContent='مرحلة '+lvl.id;slot.appendChild(nm);
    wrap.appendChild(slot);
  });
  for(let i=0;i<pos.length-1;i++){
    const a=pos[i],b=pos[i+1];
    const mx=(a.cx+b.cx)/2,my=(a.cy+b.cy)/2;
    const path=document.createElementNS('http://www.w3.org/2000/svg','path');
    path.setAttribute('d','M'+a.cx+' '+(a.cy+38)+' Q'+mx+' '+my+' '+b.cx+' '+(b.cy-38));
    path.setAttribute('stroke','#b8a070');path.setAttribute('stroke-width','3.5');
    path.setAttribute('stroke-dasharray','10,8');path.setAttribute('fill','none');
    svg.appendChild(path);
  }
}

function goTo(id){playClick();document.querySelectorAll('.screen').forEach(s=>s.classList.add('hidden'));document.getElementById(id).classList.remove('hidden');}
function goToMap(){buildMap();goTo('map-screen');}

function playLevel(id){
  curLevel=LEVELS.find(l=>l.id===id);
  curQ=0;curScore=0;hintUsed=false;picking=false;
  document.getElementById('q-bar-title').textContent='المرحلة #'+id;
  goTo('question-screen');renderQ();
}

function renderQ(){
  hintUsed=false;picking=false;updateCoins();
  const q=curLevel.qs[curQ];
  const pg=document.getElementById('q-prog');pg.innerHTML='';
  curLevel.qs.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='q-dot'+(i<curQ?' done':i===curQ?' current':'');
    pg.appendChild(d);
  });
  document.getElementById('q-cat-badge').textContent=(q.cat||'🌍');
  document.getElementById('q-text').textContent=q.q;
  const hr=document.getElementById('hint-revealed');hr.textContent='';hr.classList.remove('show');
  const ar=document.getElementById('ans-row');ar.innerHTML='';
  const letters=[...q.opts[q.a]];const show=Math.min(letters.length,8);
  for(let i=0;i<show;i++){
    const b=document.createElement('div');b.className='ans-box';b.id='ab'+i;b.textContent='_';ar.appendChild(b);
  }
  const ow=document.getElementById('opts-wrap');ow.innerHTML='';
  q.opts.forEach((opt,i)=>{
    const btn=document.createElement('button');btn.className='opt-btn pressable';
    const face=document.createElement('div');face.className='opt-face';face.textContent=opt;
    btn.appendChild(face);btn.onclick=()=>pick(i);ow.appendChild(btn);
  });
}

function pick(idx){
  if(picking)return;picking=true;
  const q=curLevel.qs[curQ];const right=idx===q.a;
  if(right){curScore++;playCorrect();}
  const btns=document.querySelectorAll('.opt-btn');
  btns.forEach(b=>b.style.pointerEvents='none');
  btns[idx].classList.add(right?'correct':'wrong');
  if(!right)btns[q.a].classList.add('correct');
  const correct=q.opts[q.a];const show=Math.min([...correct].length,8);
  for(let i=0;i<show;i++){
    const b=document.getElementById('ab'+i);
    if(b){b.textContent=[...correct][i]||'';b.classList.add(right?'correct':'wrong');}
  }
  setTimeout(()=>showFeedback(right),500);
}

function showFeedback(right){
  const q=curLevel.qs[curQ];const correctText=q.opts[q.a];
  const isLast=curQ>=curLevel.qs.length-1;
  const nextLabel=isLast?'إنهاء المرحلة':'التالي ▶';
  const nextAction=isLast?finishLevel:nextQ;
  document.getElementById('sheet-bg').classList.add('on');
  if(right){
    const earned=COIN_CORRECT;coins+=earned;updateCoins();spawnFloatCoin(earned);playCoin();
    const ctitles=['صح عليك! 🎯','ممتاز! 🌟','رائع! ✅','أحسنت! 🏅'];
    document.getElementById('cs-title').textContent=ctitles[Math.floor(Math.random()*ctitles.length)];
    document.getElementById('cs-answer-value').textContent=correctText;
    document.getElementById('cs-coins-pill').textContent='🟡 +'+earned+' عملات';
    const btn=document.getElementById('cs-next-btn');btn.textContent=nextLabel;btn.onclick=nextAction;
    document.getElementById('correct-sheet').classList.add('show');
  }else{
    playWrong();
    document.getElementById('ws-answer-value').textContent=correctText;
    const btn=document.getElementById('ws-next-btn');btn.textContent=nextLabel;btn.onclick=nextAction;
    document.getElementById('wrong-sheet').classList.add('show');
  }
}

function closeSheets(){
  document.getElementById('sheet-bg').classList.remove('on');
  document.getElementById('correct-sheet').classList.remove('show');
  document.getElementById('wrong-sheet').classList.remove('show');
}
function nextQ(){closeSheets();curQ++;renderQ();}
function finishLevel(){
  closeSheets();
  if(!done.includes(curLevel.id))done.push(curLevel.id);
  coins+=COIN_LEVEL;updateCoins();playLevelUp();
  setTimeout(showLevelComplete,200);
}
function showLevelComplete(){
  document.getElementById('lc-title').textContent='أكملت المرحلة '+curLevel.id+'!';
  document.getElementById('lc-sub').textContent='نتيجتك: '+curScore+' من '+curLevel.qs.length;
  document.getElementById('lc-coins').textContent=COIN_LEVEL;
  document.getElementById('level-complete-ov').classList.add('show');
  if(settings.fx)spawnConfetti();
}
function closeLevelComplete(){playClick();document.getElementById('level-complete-ov').classList.remove('show');buildMap();goTo('map-screen');}

// HINT
function openHintShop(){
  if(hintUsed){document.getElementById('hint-revealed').classList.add('show');return;}
  playClick();
  document.getElementById('hint-ov-text').textContent='اشترِ تلميحاً مقابل 3 عملات.';
  document.getElementById('hint-ov-bg').classList.add('on');
  document.getElementById('hint-ov').classList.add('on');
}
function closeHintShop(){playClick();document.getElementById('hint-ov-bg').classList.remove('on');document.getElementById('hint-ov').classList.remove('on');}
function buyHint(){
  if(coins<HINT_COST){alert('ليس لديك عملات كافية!');return;}
  coins-=HINT_COST;hintUsed=true;updateCoins();
  const q=curLevel.qs[curQ];
  const hr=document.getElementById('hint-revealed');
  hr.textContent='💡 '+q.hint;hr.classList.add('show');
  closeHintShop();playTone(660,0.15,'sine',0.2);
}

// EFFECTS
function spawnFloatCoin(n){
  if(!settings.fx)return;
  const el=document.createElement('div');el.className='float-coin';el.textContent='+'+n+'🟡';
  el.style.cssText='top:45%;left:47%;';document.body.appendChild(el);
  setTimeout(()=>el.remove(),1400);
}
function spawnConfetti(){
  const colors=['#f0c030','#e07020','#d04020','#50c020','#2080d0','#c030a0','#fff'];
  for(let i=0;i<90;i++){
    setTimeout(()=>{
      const c=document.createElement('div');c.className='cf';
      const s=6+Math.random()*10;
      c.style.cssText='left:'+Math.random()*100+'vw;top:-20px;width:'+s+'px;height:'+s+'px;'
        +'background:'+colors[Math.floor(Math.random()*colors.length)]+';'
        +'border-radius:'+(Math.random()>.5?'50%':'2px')+';'
        +'animation:cfFall '+(1.5+Math.random()*2.5)+'s ease forwards;';
      document.body.appendChild(c);setTimeout(()=>c.remove(),5000);
    },i*20);
  }
}

goTo('start-screen');
</script>
</body>
